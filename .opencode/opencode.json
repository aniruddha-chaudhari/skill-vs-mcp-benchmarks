{
  "$schema": "https://opencode.ai/config.json",
  "tools": {
    "chat-with-session": false,
    "read-frontmatter": false
  },
  "agent": {
    "chat-manager": {
      "tools": {
        "chat-with-session": true,
        "read-frontmatter": true
      }
    }
  },
  "mcp": {
    "qmd": {
      "type": "local",
      "command": [
        "node",
        "C:\\Users\\Aniruddha Chaudhari\\node_modules\\@tobilu\\qmd\\dist\\qmd.js",
        "mcp"
      ],
      "enabled": false,
      "timeout": 60000
    },
    "use-chrome": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": false
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": false
    },
    "fast-play": {
      "type": "local",
      "command": ["npx", "@tontoko/fast-playwright-mcp"],
      "enabled": false
    },
    "supermemory": {
      "type": "remote",
      "url": "https://mcp.supermemory.ai/mcp",
      "enabled": false
    }
  }
}
