{
  "$schema": "https://opencode.ai/config.json",
  "theme": "opencode",
  "mcp": {
    "use-chrome": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": false
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": false
    },
    "fast-play": {
      "type": "local",
      "command": ["npx", "@tontoko/fast-playwright-mcp"],
      "enabled": false
    }
  }
}
