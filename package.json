{
  "name": "adival",
  "version": "1.0.0",
  "description": "Evaluation framework and apps",
  "scripts": {
    "dev:app": "bun run --cwd apps/vite-react dev",
    "eval": "bun run eval/run-eval.ts",
    "watch-memory": "bun run watch-memory.ts",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:files": "prettier --write",
    "format:check": "prettier --check ."
  },
  "dependencies": {
