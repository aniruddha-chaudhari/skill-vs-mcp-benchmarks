{"type":"tool_use","timestamp":1773487055300,"sessionID":"ses_313f02a77ffe410EsrdD2C5NJx","part":{"id":"prt_cec10301e0014I09p5AuozR82O","sessionID":"ses_313f02a77ffe410EsrdD2C5NJx","messageID":"msg_cec100f95001iqNmdLD6JShCox","type":"tool","callID":"call_39893267","tool":"write","state":{"status":"completed","input":{"content":"import os\nimport shutil\nfrom PIL import Image\nimport hashlib\nfrom datetime import datetime\nimport json\n\ndef process_images():\n    path = \"uploads/photos/\"\n    if not os.path.exists(path):\n        print(\"Directory does not exist\")\n        return\n    \n    files = [f for f in os.listdir(path) if f.lower().endswith(('.jpg', '.png'))]\n    \n    exif_count = 0\n    hash_to_files = {}\n    renamed_count = 0\n    distribution = {}\n    \n    # First pass: extract EXIF and compute hashes\n    for file in files:\n        full_path = os.path.join(path, file)\n        try:\n            img = Image.open(full_path)\n            # Get EXIF\n            exif_data = img.getexif()\n            date_str = None\n            if exif_data and 36867 in exif_data:  # DateTimeOriginal\n                date_str = exif_data[36867]\n                try:\n                    dt = datetime.strptime(date_str, '%Y:%m:%d %H:%M:%S')\n                    exif_count += 1\n                except ValueError:\n                    date_str = None\n            \n            # Compute MD5 of raw pixels\n            pixel_hash = hashlib.md5(img.tobytes()).hexdigest()\n            if pixel_hash not in hash_to_files:\n                hash_to_files[pixel_hash] = []\n            hash_to_files[pixel_hash].append(file)\n            \n            img.close()\n        except Exception as e:\n            print(f\"Error processing {file}: {e}\")\n    \n    # Count duplicate pairs\n    duplicate_pairs = 0\n    for files_list in hash_to_files.values():\n        if len(files_list) > 1:\n            n = len(files_list)\n            duplicate_pairs += n * (n - 1) // 2\n    \n    # Second pass: rename and move\n    for file in files:\n        full_path = os.path.join(path, file)\n        try:\n            img = Image.open(full_path)\n            exif_data = img.getexif()\n            new_name = file  # default\n            year = \"unknown\"\n            if exif_data and 36867 in exif_data:\n                date_str = exif_data[36867]\n                try:\n                    dt = datetime.strptime(date_str, '%Y:%m:%d %H:%M:%S')\n                    base, ext = os.path.splitext(file)\n                    new_name = f\"{dt.year}-{dt.month:02d}-{dt.day:02d}_{dt.hour:02d}-{dt.minute:02d}-{dt.second:02d}_{base}{ext}\"\n                    renamed_count += 1\n                    year = str(dt.year)\n                except ValueError:\n                    pass\n            img.close()\n            \n            # Move to folder\n            folder = os.path.join(path, year)\n            os.makedirs(folder, exist_ok=True)\n            new_full_path = os.path.join(folder, new_name)\n            shutil.move(full_path, new_full_path)\n            \n            # Update distribution\n            if year not in distribution:\n                distribution[year] = 0\n            distribution[year] += 1\n            \n        except Exception as e:\n            print(f\"Error moving {file}: {e}\")\n    \n    # Output\n    print(f\"FilesWithEXIF: {exif_count}\")\n    print(f\"DuplicatePairs: {duplicate_pairs}\")\n    print(f\"FilesRenamed: {renamed_count}\")\n    print(f\"FolderDistribution: {json.dumps(distribution)}\")\n\nif __name__ == \"__main__\":\n    process_images()","filePath":"manager/tools/process_images.py"},"output":"Wrote file successfully.","title":"manager\\tools\\process_images.py","metadata":{"diagnostics":{},"filepath":"F:\\Aniruddha\\code\\college\\mcpserver\\manager\\tools\\process_images.py","exists":false,"truncated":false},"time":{"start":1773487009832,"end":1773487055295}}}}
