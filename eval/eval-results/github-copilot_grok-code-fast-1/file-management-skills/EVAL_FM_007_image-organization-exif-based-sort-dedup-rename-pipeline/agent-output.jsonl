{"type":"tool_use","timestamp":1773749052693,"sessionID":"ses_304521890ffeP3NG48zcnYpOpR","part":{"id":"prt_cfbae973c001PprfJ63mx8m0bm","sessionID":"ses_304521890ffeP3NG48zcnYpOpR","messageID":"msg_cfbae8a310013ktvvZe7rlLuge","type":"tool","callID":"call_29446353","tool":"write","state":{"status":"completed","input":{"content":"import os\nfrom PIL import Image\nimport hashlib\nfrom collections import defaultdict\nimport json\nimport shutil\nfrom datetime import datetime\n\n# Find all jpg png\nfiles = []\nfor root, dirs, filenames in os.walk('uploads/photos'):\n    for f in filenames:\n        if f.lower().endswith(('.jpg', '.png')):\n            files.append(os.path.join(root, f))\n\n# Extract EXIF\nexif_dates = {}\nfor f in files:\n    try:\n        img = Image.open(f)\n        exif = img._getexif()\n        if exif and 36867 in exif:  # DateTimeOriginal\n            date_str = exif[36867]\n            # parse date_str, assume format 'YYYY:MM:DD HH:MM:SS'\n            date_obj = datetime.strptime(date_str, '%Y:%m:%d %H:%M:%S')\n            exif_dates[f] = date_obj\n        img.close()\n    except Exception as e:\n        pass\n\nfiles_with_exif = len(exif_dates)\n\n# Compute MD5 of pixels\nmd5s = {}\nfor f in files:\n    try:\n        img = Image.open(f)\n        # Get pixel data as bytes\n        pixels = img.tobytes()\n        md5 = hashlib.md5(pixels).hexdigest()\n        md5s[f] = md5\n        img.close()\n    except Exception as e:\n        pass\n\n# Find duplicates\nmd5_to_files = defaultdict(list)\nfor f, md5 in md5s.items():\n    md5_to_files[md5].append(f)\n\nduplicate_pairs = 0\nfor group in md5_to_files.values():\n    if len(group) > 1:\n        duplicate_pairs += len(group) * (len(group) - 1) // 2  # number of unique pairs\n\n# Now, rename and move\n# First, create the subfolders if not exist\nos.makedirs('uploads/photos/unknown', exist_ok=True)\n# Assume years from 2000 to 2030\nfor year in range(2000, 2031):\n    os.makedirs(f'uploads/photos/{year}', exist_ok=True)\n\n# Now, for each file\nrenamed_count = 0\nfolder_dist = defaultdict(int)\n\nfor f in files:\n    base = os.path.basename(f)\n    if f in exif_dates:\n        date = exif_dates[f]\n        year = date.year\n        date_str = date.strftime('%Y-%m-%d_%H-%M-%S')\n        new_name = f'{date_str}_{base}'\n        new_path = os.path.join('uploads', 'photos', str(year), new_name)\n        # Move\n        shutil.move(f, new_path)\n        renamed_count += 1\n        folder_dist[str(year)] += 1\n    else:\n        # Move to unknown\n        new_path = os.path.join('uploads', 'photos', 'unknown', base)\n        if f != new_path:  # if not already there\n            shutil.move(f, new_path)\n        folder_dist['unknown'] += 1\n\n# Output\nprint(f'FilesWithEXIF: {files_with_exif}')\nprint(f'DuplicatePairs: {duplicate_pairs}')\nprint(f'FilesRenamed: {renamed_count}')\nprint(f'FolderDistribution: {json.dumps(dict(folder_dist))}')","filePath":"manager/tools/image_process.py"},"output":"Wrote file successfully.","title":"manager\\tools\\image_process.py","metadata":{"diagnostics":{},"filepath":"D:\\Adu\\col\\js\\project\\adival\\manager\\tools\\image_process.py","exists":false,"truncated":false},"time":{"start":1773749049165,"end":1773749052691}}}}
