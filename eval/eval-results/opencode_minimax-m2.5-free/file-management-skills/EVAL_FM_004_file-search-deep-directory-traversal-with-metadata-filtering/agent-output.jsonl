icates:\n    print(f\"  {d[1].relative_to(base_dir)} == {d[2].relative_to(base_dir)}\")\n","filePath":"D:\\Adu\\col\\js\\project\\adival\\analyze_files.py"},"output":"Wrote file successfully.","title":"analyze_files.py","metadata":{"diagnostics":{},"filepath":"D:\\Adu\\col\\js\\project\\adival\\analyze_files.py","exists":false,"truncated":false},"time":{"start":1773751626815,"end":1773751631181}}}}
